{
    "ConnectionStrings": {
        "DefaultConnection": "Data Source=/var/data/ticketsystem.db"
    },
    "Jwt": {
        "Key": "REPLACE_WITH_STRONG_SECRET_IN_PRODUCTION_ENV_VAR",
        "Issuer": "TicketSystemAPI",
        "Audience": "TicketSystemFrontend",
        "ExpiresInMinutes": 30,
        "RefreshExpiresInDays": 7
    },
    "EmailSettings": {
        "Host": "REPLACE_WITH_SMTP_HOST",
        "Port": "587",
        "Username": "REPLACE_WITH_SMTP_USER",
        "Password": "REPLACE_WITH_SMTP_PASSWORD",
        "EnableSsl": "true",
        "DisplayName": "TicketSystem Soporte"
    },
    "AppSettings": {
        "FrontendBaseUrl": "https://YOUR_DOMAIN",
        "AllowedCorsOrigins": [
            "https://YOUR_DOMAIN"
        ]
    }
}